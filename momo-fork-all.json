  "dns": {
    "servers": [
      {
        "tag": "local",
        "type": "udp",
        "server": "116.116.116.116"
      },
      {
        "tag": "public",
        "type": "https",
        "server": "dns.alidns.com",
        "domain_resolver": "local"
      },
      {
        "tag": "foreign",
        "type": "https",
        "server": "one.one.one.one",
        "detour": "🚀 手动选择"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "direct",
        "server": "local"
      },
      {
        "clash_mode": "global",
        "server": "fakeip"
      },
      {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-private",
          "geosite-google-cn",
          "geosite-cn",
          "custom-direct-domain"
        ],
        "server": "local"
      },
      {
        "rule_set": [
          "geosite-openai",
          "geosite-category-ai-!cn",
          "geosite-gfw",
          "geosite-google"
        ],
        "server": "fakeip"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fakeip",
        "rewrite_ttl": 1
      }
    ],
    "final": "foreign",
    "strategy": "prefer_ipv4",
    "independent_cache": true,
    "reverse_mapping": true
  },
